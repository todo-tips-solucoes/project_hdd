# BMAD installer output — regenerável via `npx bmad-method install` (ver CLAUDE.md).
# Ignorado todo o _bmad/ exceto custom/, que contém os overrides persistentes
# committable (pinos de time/pessoais) e nunca é tocado pelo installer.
_bmad/*
!_bmad/custom/
# ...mas o config.user.toml de custom/ é pessoal (gitignored per CLAUDE.md).
_bmad/custom/config.user.toml

# Variáveis de ambiente / segredos — nunca versionar (repo público).
# .env.example fica committable por ser apenas template (sem segredos).
.env
.env.*
*.env
!.env.example
!.env.*.example

# Python / uv (HDD v2 — backend). uv.lock fica committable (reproducibilidade);
# .venv e caches nunca.
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / Next.js (frontend, futuro). node_modules nunca committable.
node_modules/
.next/
dist/
coverage/
*.tsbuildinfo

# Smoke / runtime evidence — outputs ad-hoc de scripts/smoke-*.sh (Story 1.c.7,
# resolve open item O-1). Ficheiros têm timestamps non-deterministic; recriam-se
# correndo os smoke scripts manualmente.
.smoke-evidence/

# SQLite state store (Story 1.a.5) — runtime DB; nunca committable.
# WAL/SHM são sidecar files do journal_mode=WAL.
*.db
*.db-wal
*.db-shm
.hdd-state.db*

# Audit trail (Story 1.a.6) — runtime JSONL + .tsr stubs; nunca committable.
# Backup via Litestream (Story 1.c.3) → R2 EU.
_bmad-output/audit/
