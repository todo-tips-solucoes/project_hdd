# Template de configuração (sem segredos reais). Copie para .env e ajuste.
#
# DEV: o pydantic-settings lê deste .env (env_prefix=HDD_).
# PROD (Docker Swarm): NÃO use .env para segredos — eles vêm de /run/secrets.
#   ⚠️ O env_prefix "HDD_" TAMBÉM se aplica ao nome dos arquivos de secret:
#      o arquivo deve chamar-se `hdd_pg_dsn` (NÃO `pg_dsn`). Ver
#      docs/runbooks/secrets.md.

# --- Núcleo ------------------------------------------------------------------
HDD_PG_DSN=postgresql://hdd:hdd_dev@localhost:5433/hdd   # secret em prod: hdd_pg_dsn
HDD_LLM_DRIVER=subscription
# HDD_MODEL=haiku
HDD_LOG_LEVEL=INFO

# --- Painel Web / OAuth GitHub (Epic 4) --------------------------------------
HDD_GITHUB_CLIENT_ID=
HDD_GITHUB_CLIENT_SECRET=                                # secret em prod: hdd_github_client_secret
HDD_GITHUB_ALLOWLIST=                                    # CSV de logins; vazio = nega tudo
HDD_SESSION_SECRET=dev-insecure-session-secret-change-me # secret em prod: hdd_session_secret
HDD_PANEL_BASE_URL=http://localhost:3000
HDD_CORS_ORIGINS=http://localhost:3000

# --- Canal WhatsApp / clihelper + webhook n8n (Epic 4) -----------------------
HDD_CLIHELPER_BASE_URL=
HDD_CLIHELPER_TOKEN=                                     # secret em prod: hdd_clihelper_token
HDD_NOTIFIER_MIN_INTERVAL_S=1.0
HDD_WEBHOOK_HMAC_SECRET=                                 # secret em prod: hdd_webhook_hmac_secret
