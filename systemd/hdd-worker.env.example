# /etc/hdd/secrets.env — EnvironmentFile da systemd unit (Story 1.c.1).
#
# Copiar para /etc/hdd/secrets.env com permissão 0600 e owner hdd-worker:
#   install -o hdd-worker -g hdd-worker -m 0600 hdd-worker.env.example /etc/hdd/secrets.env
#
# O provisioning seguro (user dedicado + 0600 + ACL) é a Story 1.c.2 (AO-16).
# Este ficheiro é só o template documentado.

# Chave da API Anthropic (obrigatória — parseEnv fail-closed em falta).
ANTHROPIC_API_KEY=

# Token do app clihelper (obrigatório — Story 1.c.2 Q-C2-1; consumido em Epic 3).
CLIHELPER_TOKEN=

# Porta do endpoint /healthz (default 8080 se ausente).
PORT=8080
