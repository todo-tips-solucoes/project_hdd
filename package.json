{
  "name": "hdd-worker",
  "version": "0.0.1",
  "description": "HORSE DRIVEN DEVELOPMENT worker (HDD M0). Bun-based daemon for the BMAD-driven autonomous pipeline.",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "hdd-worker": "./dist/hdd-worker"
  },
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "build": "bun build --compile src/main.ts --outfile dist/hdd-worker",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:security": "bun test tests/security tests/services/apply-diff.security.test.ts",
    "check:webhook-schema": "bun run scripts/check-webhook-schema.ts",
    "lint": "biome check src tests && eslint --no-error-on-unmatched-pattern src tests",
    "lint:fix": "biome check --write src tests && eslint --no-error-on-unmatched-pattern --fix src tests",
    "format": "biome format --write src tests",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/cli/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "audit:verify": "bun run scripts/verify-audit-chain.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "fast-check": "^4.8.0",
    "typescript-eslint": "^8.60.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "neverthrow": "^8.2.0",
    "zod": "^4.4.3"
  }
}
