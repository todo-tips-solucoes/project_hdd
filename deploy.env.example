# Variáveis de deploy (Swarm) — Story 5.1.
# Copie para deploy.env e exporte ANTES do `docker stack deploy`:
#   set -a && . ./deploy.env && set +a && docker stack deploy -c stack.yaml hdd
#
# ⚠️ Segredos (DSN, session_secret, client_secret, token, hmac) NÃO vão aqui —
#    são Docker secrets (docs/runbooks/secrets.md). Aqui só config + tokens de
#    runtime que o operador optou por gerir via .env.

# --- Domínio / TLS ----------------------------------------------------------
HDD_DOMAIN=hdd.example.com
CADDY_ACME_EMAIL=operador@example.com

# --- Imagens (registry/tag) -------------------------------------------------
HDD_IMAGE_API=hdd-api:latest
HDD_IMAGE_WORKER=hdd-worker:latest
HDD_IMAGE_FRONTEND=hdd-frontend:latest

# --- API / OAuth (não-segredos) ---------------------------------------------
HDD_LLM_DRIVER=subscription
HDD_LOG_LEVEL=INFO
HDD_GITHUB_CLIENT_ID=
HDD_GITHUB_ALLOWLIST=
HDD_CLIHELPER_BASE_URL=

# --- Worker -----------------------------------------------------------------
HDD_WORKER_REPLICAS=1
HDD_MODEL=
# ⚠️ Tokens de runtime (Claude Code OAuth + gh) NÃO ficam aqui — são Docker
# secrets `hdd_claude_oauth_token` e `hdd_gh_token` (Story 6.4 hardening;
# ver docs/runbooks/secrets.md). O entrypoint os carrega para o ENV dos CLIs.

# --- Epic 6: execução real (workspace + PR/merge + verify no sandbox) --------
# Repo-alvo que cada onda clona (vazio → sem workspace; verify defere ao gate).
HDD_REPO_URL=
# Slug owner/name p/ `gh --repo` no merge da API (Story 6.8). Ex.: org/repo.
HDD_REPO_SLUG=
# Comando de teste rodado no sandbox de verify (Story 6.3).
HDD_VERIFY_COMMAND=pytest -q
HDD_SANDBOX_IMAGE=hdd-sandbox:latest
HDD_SANDBOX_NETWORK=none
# Caminho dos workspaces efêmeros — DEVE ser um path do HOST (o verify monta-o no
# sandbox via daemon do host). Bind-montado no worker no mesmo caminho.
HDD_WORKSPACE_ROOT=/var/lib/hdd-workspaces
# gid do grupo `docker` no host (getent group docker | cut -d: -f3) — dá ao
# worker (uid 10001) acesso ao socket sem rodar como root.
HDD_DOCKER_GID=999
