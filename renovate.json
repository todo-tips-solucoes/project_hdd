{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Lisbon",
  "schedule": ["before 6am on monday"],
  "packageRules": [
    {
      "description": "D-04.11': patch/pin/digest automerge apos CI green.",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "D-04.11': minor/major exigem PR com revisao manual.",
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false
    },
    {
      "description": "D-04.11': vulnerabilidades automerge imediato (qualquer tipo).",
      "matchUpdateTypes": ["patch", "minor", "major"],
      "isVulnerabilityAlert": true,
      "automerge": true
    },
    {
      "description": "D-04.11' (architecture.md:736): runtime + binarios criticos NUNCA automerge, nem por security — regra final, vence as anteriores (estabilidade do runtime > velocidade do patch).",
      "matchPackageNames": [
        "bun",
        "oven-sh/setup-bun",
        "benbjohnson/litestream",
        "rclone/rclone"
      ],
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  }
}
